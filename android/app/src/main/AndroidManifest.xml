<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- #2 SMS 자동 수신 -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <!-- 백그라운드 추출 결과 알림 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 고신뢰도 자동 등록 / 빠른 추가·되돌리기 (CalendarProvider 직접 쓰기) -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CalendarAgent">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- #1 카카오톡 알림 가로채기 (사용자가 '알림 접근' 허용해야 동작) -->
        <service
            android:name=".KakaoNotificationListener"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- #2 SMS 수신 브로드캐스트 -->
        <receiver
            android:name=".SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- 이벤트함 (감지 일정 목록/관리) -->
        <activity
            android:name=".EventListActivity"
            android:exported="false" />

        <!-- 일정 편집 -->
        <activity
            android:name=".EventEditActivity"
            android:exported="false" />

        <!-- 설정 -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <!-- 첫 실행 설정 가이드 -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false" />

        <!-- 알림 액션(추가/무시/되돌리기) 처리. 앱 내부 전용. -->
        <receiver
            android:name=".EventActionReceiver"
            android:exported="false" />
    </application>
</manifest>
