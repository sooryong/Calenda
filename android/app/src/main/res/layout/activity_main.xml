<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 1. 모델 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_model"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/modelStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/model_missing" />

        <Button
            android:id="@+id/loadModelButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/import_model" />

        <!-- 2. 입력 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/title_input"
            android:textStyle="bold"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/channelInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/channel_hint"
            android:inputType="text" />

        <EditText
            android:id="@+id/senderInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/sender_hint"
            android:inputType="text" />

        <EditText
            android:id="@+id/receivedAtInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/received_at_hint"
            android:inputType="text" />

        <EditText
            android:id="@+id/messageInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/message_hint"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top" />

        <Button
            android:id="@+id/extractButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:text="@string/extract" />

        <!-- 3. 결과 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/title_result"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:text="" />

        <Button
            android:id="@+id/addCalendarButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:text="@string/add_calendar" />

    </LinearLayout>
</ScrollView>
