<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginBottom="12dp" />

        <!-- Google 캘린더 (앱의 핵심: 일정 등록 대상) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/section_calendar"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="?attr/colorPrimary" />

        <Button
            android:id="@+id/calendarButton"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="start|center_vertical"
            android:text="@string/calendar_select" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/calendar_desc"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- 모델 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/listDivider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_model"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="?attr/colorPrimary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/model_purpose"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:id="@+id/modelInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- 자동 등록 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/listDivider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_autoadd"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/autoAddSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_add_label" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_add_desc"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:id="@+id/thresholdLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/thresholdSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="50"
            android:max="100" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/strictRegisterSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/strict_register_label" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/strict_register_desc"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- 채널 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/listDivider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/channels_label"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/chKakao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ch_kakao" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/chSms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ch_sms" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/chGmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ch_gmail" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/gmail_via_notif"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- 백그라운드 수집 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/listDivider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/collector_section"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/collectorSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/collector_label" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/collector_desc"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <Button
            android:id="@+id/batteryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/battery_exempt" />

        <!-- 학습 데이터 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:background="?android:attr/listDivider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/learning_label"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="?attr/colorPrimary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/export_desc"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <Button
            android:id="@+id/exportButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:enabled="false"
            android:text="@string/learning_label" />

        <Button
            android:id="@+id/debugButton"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/debug_open" />
    </LinearLayout>
</ScrollView>
